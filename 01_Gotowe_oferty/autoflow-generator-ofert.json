      "name": "Odpowiedź — Błąd walidacji",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [680, 420]
    },
    {
      "parameters": {
        "jsCode": "const error = $input.first().json;\nconsole.error('Claude API Error:', JSON.stringify(error));\n\nreturn [{\n  json: {\n    success: false,\n    error: 'Błąd komunikacji z Claude API. Spróbuj ponownie za chwilę.',\n    details: error.message || 'Nieznany błąd'\n  }\n}];"
      },
